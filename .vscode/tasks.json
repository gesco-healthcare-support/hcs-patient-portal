{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ng: build-and-serve",
      "type": "shell",
      "command": "npx ng build --configuration development && npx serve -s dist/CaseEvaluation/browser -p 4200",
      "options": {
        "cwd": "${workspaceFolder}/angular"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "owner": "angular",
        "fileLocation": ["relative", "${workspaceFolder}/angular"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+)\\s+-\\s+(error|warning)\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Building\\.\\.\\.$",
          "endsPattern": "^.*Accepting connections at.*$"
        }
      }
    },
    {
      "label": "dotnet: restore",
      "type": "process",
      "command": "dotnet",
      "args": ["restore"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "dotnet: build",
      "type": "process",
      "command": "dotnet",
      "args": ["build", "HealthcareSupport.CaseEvaluation.slnx", "-c", "Debug"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
