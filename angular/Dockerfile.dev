FROM node:20-alpine
WORKDIR /app

COPY package.json yarn.lock /app/
RUN yarn install --frozen-lockfile

COPY . /app

# Add browser-sync for serving the built dist over HTTP with live-reload-on-
# rebuild semantics (handy when you re-run `ng build` inside the container).
RUN yarn add --dev browser-sync@3

ARG NG_CONFIG=docker
ENV NG_CONFIG=${NG_CONFIG}

# 2026-05-08: dev-entrypoint.sh used to be embedded inline as a `COPY <<'EOF'`
# heredoc. That made the script bytes inherit this Dockerfile's line endings,
# which meant a CRLF Dockerfile (Git's default `core.autocrlf=true` on Windows)
# produced a script with `#!/bin/sh\r\n` and Linux failed to exec the
# carriage-return-suffixed interpreter. The fix is to keep the script as a
# real file and COPY it -- combined with the .gitattributes rule that pins
# *.sh to LF, the script bytes are guaranteed Unix-clean regardless of which
# host any teammate clones on. dynamic-env.json is written by the entrypoint
# from container env vars into /app, then copied into dist after `ng build`
# completes. The background `ensure_dynamic_env` loop keeps a copy in dist as
# a defensive measure in case dist is ever cleared.
#
# OBS-22 (2026-05-22): `ng build --watch` + `CHOKIDAR_USEPOLLING=1` removed.
# Container now does a one-shot `ng build`; iterating on source means
# `docker compose restart angular`.
COPY dev-entrypoint.sh /app/dev-entrypoint.sh
RUN chmod +x /app/dev-entrypoint.sh

EXPOSE 80

ENTRYPOINT ["/app/dev-entrypoint.sh"]
