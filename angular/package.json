{
  "name": "CaseEvaluation",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "symlinks:setup": "cd scripts && pwsh ./setup-symlinks.ps1",
    "symlinks:remove": "cd scripts && pwsh ./remove-symlinks.ps1",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json}\"",
    "prepare": "cd .. && husky angular/.husky"
  },
  "private": true,
  "dependencies": {
    "@abp/ng.components": "~10.0.2",
    "@abp/ng.core": "~10.0.2",
    "@abp/ng.feature-management": "~10.0.2",
    "@abp/ng.oauth": "~10.0.2",
    "@abp/ng.setting-management": "~10.0.2",
    "@abp/ng.theme.shared": "~10.0.2",
    "@angular/animations": "~20.3.19",
    "@angular/common": "~20.3.19",
    "@angular/compiler": "~20.3.19",
    "@angular/core": "~20.3.19",
    "@angular/forms": "~20.3.19",
    "@angular/localize": "~20.3.19",
    "@angular/platform-browser": "~20.3.19",
    "@angular/platform-browser-dynamic": "~20.3.19",
    "@angular/router": "~20.3.19",
    "@rxweb/reactive-form-validators": "^13",
    "@volo/abp.commercial.ng.ui": "~10.0.2",
    "@volo/abp.ng.account": "~10.0.2",
    "@volo/abp.ng.audit-logging": "~10.0.2",
    "@volo/abp.ng.file-management": "~10.0.2",
    "@volo/abp.ng.gdpr": "~10.0.2",
    "@volo/abp.ng.identity": "~10.0.2",
    "@volo/abp.ng.language-management": "~10.0.2",
    "@volo/abp.ng.openiddictpro": "~10.0.2",
    "@volo/abp.ng.saas": "~10.0.2",
    "@volo/abp.ng.text-template-management": "~10.0.2",
    "@volosoft/abp.ng.theme.lepton-x": "~5.0.2",
    "ngx-mask": "~20.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.0.0",
    "zone.js": "~0.15.0"
  },
  "resolutions": {
    "vite": ">=7.3.2",
    "rollup": ">=4.59.0",
    "tar": ">=7.5.11",
    "lodash": ">=4.18.0",
    "minimatch": ">=3.1.4",
    "picomatch": ">=4.0.4",
    "nanoid": ">=5.0.9",
    "qs": ">=6.14.2",
    "immutable": ">=5.1.5",
    "flatted": ">=3.4.2",
    "brace-expansion": ">=1.1.13"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.html": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{scss,css,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@abp/ng.schematics": "~10.0.2",
    "@angular-eslint/builder": "~20.0.0",
    "@angular-eslint/eslint-plugin": "~20.0.0",
    "@angular-eslint/eslint-plugin-template": "~20.0.0",
    "@angular-eslint/schematics": "~20.0.0",
    "@angular-eslint/template-parser": "~20.0.0",
    "@angular/build": "~20.3.24",
    "@angular/cli": "~20.3.24",
    "@angular/compiler-cli": "~20.3.19",
    "@angular/language-service": "~20.3.19",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/jasmine": "~3.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.1.6",
    "jasmine-core": "~4.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.1.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.0.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.0",
    "typescript": "~5.8.0"
  }
}
