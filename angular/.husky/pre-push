#!/usr/bin/env sh

echo "Running pre-push checks..."

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# Full secret scan (entire working tree, not just staged)
if command -v gitleaks > /dev/null 2>&1; then
  gitleaks detect --verbose --source "$REPO_ROOT"
  if [ $? -ne 0 ]; then
    echo "Gitleaks found secrets. Do NOT push. Fix immediately."
    exit 1
  fi
else
  echo "  Warning: gitleaks not installed. Skipping full secret scan."
fi

# Backend build check (Debug config for speed; CI runs Release on PR).
# Under WSL, `dotnet` alone is not resolvable by sh/dash; fall back to
# `dotnet.exe` so Windows dotnet is invoked via WSL interop.
DOTNET="dotnet"
command -v "$DOTNET" > /dev/null 2>&1 || DOTNET="dotnet.exe"

echo "  Building backend (Debug)..."
"$DOTNET" build HealthcareSupport.CaseEvaluation.slnx -c Debug --nologo -v q
if [ $? -ne 0 ]; then
  echo "Backend build failed. Fix before pushing."
  exit 1
fi

echo "Pre-push checks passed."
