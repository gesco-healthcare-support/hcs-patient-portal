#!/usr/bin/env sh

# Enforce conventional commit messages.
# commitlint is installed in angular/, so invoke from there.
REPO_ROOT="$(git rev-parse --show-toplevel)"

# Git passes COMMIT_EDITMSG's path differently depending on whether the commit
# happens in a normal checkout or a linked worktree:
#   - normal checkout: $1 is relative to the worktree root (e.g. ".git/COMMIT_EDITMSG")
#   - linked worktree: $1 is absolute (points to <main>/.git/worktrees/<name>/COMMIT_EDITMSG)
# Match absolute paths (Unix /path, Windows C:/path, Windows C:\path) and
# pass them through untouched; otherwise join with REPO_ROOT.
case "$1" in
  /*|[A-Za-z]:/*|[A-Za-z]:\\*) COMMIT_MSG_FILE="$1" ;;
  *)                           COMMIT_MSG_FILE="$REPO_ROOT/$1" ;;
esac

# Under WSL, Windows Node (bundled with Windows-installed node_modules) cannot
# parse /mnt/... paths. Convert to a Windows path so Windows Node can read it.
if grep -qi microsoft /proc/version 2>/dev/null && command -v wslpath > /dev/null 2>&1; then
  COMMIT_MSG_FILE="$(wslpath -w "$COMMIT_MSG_FILE")"
fi

( cd "$REPO_ROOT/angular" && npx --no -- commitlint --edit "$COMMIT_MSG_FILE" )
