#!/usr/bin/env sh

echo "Running pre-commit checks..."

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# 1. SECRET DETECTION (most critical for public repo)
if command -v gitleaks > /dev/null 2>&1; then
  echo "  Scanning for secrets..."
  gitleaks protect --staged --verbose --source "$REPO_ROOT"
  if [ $? -ne 0 ]; then
    echo "Gitleaks found secrets in staged files. Fix before committing."
    exit 1
  fi
else
  echo "  Warning: gitleaks not installed. Skipping secret scan."
  echo "  Install (WSL):       curl -sSfL https://github.com/gitleaks/gitleaks/releases/download/v8.21.2/gitleaks_8.21.2_linux_x64.tar.gz | tar -xz -C ~/.local/bin gitleaks"
  echo "  Install (Git Bash):  see CONTRIBUTING.md \"Activating Local Git Hooks\""
fi

# 2. ANGULAR LINT + FORMAT (only staged files matching lint-staged config)
if [ -d "$REPO_ROOT/angular/node_modules" ]; then
  echo "  Linting staged Angular files..."
  ( cd "$REPO_ROOT/angular" && npx --no -- lint-staged )
  LINT_EXIT=$?
  if [ $LINT_EXIT -ne 0 ]; then
    echo "Angular lint/format failed. Fix before committing."
    exit 1
  fi
fi

# 3. DOTNET FORMAT CHECK (only staged .cs files).
# Under WSL, `dotnet` alone is not resolvable by sh/dash; fall back to
# `dotnet.exe` so Windows dotnet is invoked via WSL interop.

# 3a. Reject .cs filenames containing spaces -- non-standard and breaks
# argument passing to dotnet format. Rename the file before committing.
# Emergency override: git commit --no-verify (admin use only).
BAD_CS_NAMES=$(git diff --cached --name-only --diff-filter=ACM -- '*.cs' | \
  while IFS= read -r f; do
    case "$(basename "$f")" in *' '*) printf '%s\n' "$f" ;; esac
  done)
if [ -n "$BAD_CS_NAMES" ]; then
  echo "ERROR: C# filenames with spaces are not allowed:"
  echo "$BAD_CS_NAMES" | sed 's/^/  /'
  echo "  Rename before committing. Emergency override: git commit --no-verify"
  exit 1
fi

# 3b. Run dotnet format --verify-no-changes on every staged .cs file.
# Paths are joined with ';' (dotnet format's documented multi-path separator)
# and passed as a single quoted argument so spaces in directory paths survive.
# Semicolons in .cs paths are invalid on Windows, so this separator is safe.
CS_FILES_RAW=$(git diff --cached --name-only --diff-filter=ACM -- '*.cs')
if [ -n "$CS_FILES_RAW" ]; then
  DOTNET="dotnet"
  command -v "$DOTNET" > /dev/null 2>&1 || DOTNET="dotnet.exe"

  CS_FILES_JOINED=$(printf '%s' "$CS_FILES_RAW" | tr '\n' ';' | sed 's/;$//')

  echo "  Checking C# formatting..."
  "$DOTNET" format HealthcareSupport.CaseEvaluation.slnx \
    --verify-no-changes --include "$CS_FILES_JOINED"
  if [ $? -ne 0 ]; then
    echo "C# formatting issues found. Run 'dotnet format' to fix."
    exit 1
  fi
fi

echo "Pre-commit checks passed."
