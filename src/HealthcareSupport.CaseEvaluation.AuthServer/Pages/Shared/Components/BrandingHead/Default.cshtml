@model HealthcareSupport.CaseEvaluation.Pages.Shared.Components.BrandingHead.BrandingHeadViewModel
@*
    Phase E (2026-06-25): per-office login branding. Overrides the LeptonX
    --lpx-logo CSS variable with the current office's logo (data URI) so the
    login + account pages show the office's logo. Rendered only when the office
    has a logo; otherwise the static global-styles.css default applies. This block
    is appended at Head.Last, so it wins over the bundle by source order.
*@
@if (!string.IsNullOrEmpty(Model.LogoDataUri))
{
    <style>
        :root {
            --lpx-logo: url('@Model.LogoDataUri');
            --lpx-logo-icon: url('@Model.LogoDataUri');
        }
    </style>
}
