@model HealthcareSupport.CaseEvaluation.Pages.Shared.Components.BrandingHead.BrandingHeadViewModel
@*
    Login branding: overrides the LeptonX --lpx-logo CSS variable (Head.Last, so it
    wins over the bundle). The view component resolves LogoCss to the host Evaluators
    crest, the office's uploaded logo, or an SVG wordmark of the office name when no
    logo exists -- so the static global-styles.css default never shows a wrong brand.
*@
@if (!string.IsNullOrEmpty(Model.LogoCss))
{
    <style>
        :root {
            --lpx-logo: url('@Model.LogoCss');
            --lpx-logo-icon: url('@Model.LogoCss');
        }
    </style>
}
