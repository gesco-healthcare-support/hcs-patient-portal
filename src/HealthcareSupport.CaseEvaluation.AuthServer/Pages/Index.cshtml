@page
@using HealthcareSupport.CaseEvaluation.Pages
@using Volo.Abp.AspNetCore.Mvc.UI.Theming
@model IndexModel
@inject ITheme Theme
@{
    Layout = Theme.GetEmptyLayout();
}
@*
    OnGet always returns a LocalRedirect to /Account/Login. This template
    is only rendered if the redirect somehow fails to fire, in which case
    we surface a minimal fallback message -- no internal OpenIddict
    application metadata or Swagger client links exposed.
*@
<div style="padding:2rem;font-family:Arial,sans-serif;text-align:center;">
    <p>Redirecting to sign in...</p>
</div>
