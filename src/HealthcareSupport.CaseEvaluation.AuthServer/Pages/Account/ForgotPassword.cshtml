@page
@model HealthcareSupport.CaseEvaluation.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}
@*
    Custom Razor view for /Account/ForgotPassword. Filesystem precedence
    overrides the stock AbpAccountPublicWeb RCL page so this view + its
    PageModel substitute for the stock pair. See ForgotPassword.cshtml.cs
    for the rationale.

    Layout mirrors Pages/Account/ResendVerification.cshtml: the
    account-card / account-content wrapper inherits AuthServer _Layout
    via Pages/_ViewImports.cshtml + LeptonX theme, so visual rhythm
    (logo, card width, spacing, footer) stays consistent with stock
    Login + Register pages.

    Accessibility:
      - Single h1 declares the page topic per WCAG 2.1 SC 2.4.6.
      - Form has explicit label-for + aria-describedby pointing at the
        helper text.
      - The submit button gets a title attribute mirroring its visible
        label so AT users hear context even when scanning links.
      - Status banner uses role="status" + aria-live="polite" so screen
        readers announce success without moving focus.
      - TempData["ErrorMessage"] (set by ResetPasswordModel when a
        reset link is invalid / expired) is rendered as a red banner
        with role="alert" so the user sees the reason they were bounced
        back here.
*@

<div class="account-card">
    <div class="account-content">

        <h1 class="text-center mt-4 mb-3">Forgot your password?</h1>

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger mt-3" role="alert">
                @errorMessage
            </div>
        }

        @if (Model.RequestSubmitted)
        {
            <div class="alert alert-success mt-3" role="status" aria-live="polite">
                If the email matches an account, we sent a reset link.
                Check your inbox and spam folder.
            </div>
        }

        <p class="mt-3" id="forgot-password-intro">
            Enter your email and we'll send you a reset link.
        </p>

        <form method="post" asp-page="ForgotPassword" novalidate>
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="form-group mt-3">
                <label asp-for="Email" class="form-label">Email address</label>
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       autocomplete="email"
                       inputmode="email"
                       aria-describedby="forgot-password-intro"
                       required />
                @*
                    No class= here. Setting one in source triggers ASP.NET
                    Core's AddClass() merge path which wraps the existing
                    value in ClassAttributeHtmlContent; its ToString() leaks
                    the FQN type name into the rendered class attribute
                    (audit findings FL2 / RPL2 2026-05-18). Empty source ->
                    fresh class attr set by the TagHelper, no merge, no
                    leak. Red error styling lives in global-styles.css
                    against the .field-validation-error class.
                *@
                <span asp-validation-for="Email"></span>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit"
                        class="btn btn-primary btn-lg"
                        title="Send reset link">
                    Send reset link
                </button>
            </div>
        </form>

        <hr class="my-4" />

        <p class="text-center text-muted small">
            Remembered your password? <a href="~/Account/Login">Sign in</a>.
        </p>

    </div>
</div>
