@page
@model HealthcareSupport.CaseEvaluation.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset your password";
}
@*
    Custom Razor view for /Account/ResetPassword. Filesystem precedence
    overrides the stock AbpAccountPublicWeb RCL page so this view + its
    PageModel substitute for the stock pair. See ResetPassword.cshtml.cs
    for the rationale.

    Layout mirrors Pages/Account/ResendVerification.cshtml + ForgotPassword.cshtml
    (same account-card / account-content wrapper, same accessibility
    attrs, same submit button styling).

    Hidden fields carry UserId / ResetToken / ReturnUrl through the POST
    so the AppService can validate the token against the user. These
    arrive on GET as querystring params (the reset email link is
    {authServer}/Account/ResetPassword?userId=X&resetToken=Y&returnUrl=Z).
*@

<div class="account-card">
    <div class="account-content">

        <h1 class="text-center mt-4 mb-3">Reset your password</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mt-3" role="alert">
                @Model.ErrorMessage
            </div>
        }

        <p class="mt-3" id="reset-password-intro">
            Choose a new password. We'll sign you in after you save.
        </p>

        <form method="post" asp-page="ResetPassword" novalidate>
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="ResetToken" />
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="form-group mt-3">
                <label asp-for="Password" class="form-label">New password</label>
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       autocomplete="new-password"
                       aria-describedby="reset-password-intro password-helper"
                       required />
                @* Drop class= -- audit FL2 / RPL2; see ForgotPassword.cshtml for rationale. *@
                <span asp-validation-for="Password"></span>
                <small id="password-helper" class="form-text text-muted">
                    Use 8+ characters with a number and a symbol.
                </small>
            </div>

            <div class="form-group mt-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirm new password</label>
                <input asp-for="ConfirmPassword"
                       type="password"
                       class="form-control"
                       autocomplete="new-password"
                       required />
                @* Drop class= -- audit FL2 / RPL2; see ForgotPassword.cshtml for rationale. *@
                <span asp-validation-for="ConfirmPassword"></span>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit"
                        class="btn btn-primary btn-lg"
                        title="Reset password">
                    Reset password
                </button>
            </div>
        </form>

        <hr class="my-4" />

        <p class="text-center text-muted small">
            Need a new reset link? <a asp-page="ForgotPassword">Request one</a>.
        </p>

        @* T4 (2026-05-27 userflow-fixes-batch2): direct sign-in nav so a
           user who decides not to reset (or for whom reset fails) is not
           stuck. Matches the symmetry on ForgotPassword / ResendVerification. *@
        <p class="text-center text-muted small">
            Remembered your password? <a href="~/Account/Login">Sign in</a>.
        </p>

    </div>
</div>
