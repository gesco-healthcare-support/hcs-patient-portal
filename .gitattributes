**/wwwroot/libs/** linguist-vendored

# Shell scripts must keep LF endings (Docker containers run Linux)
*.sh text eol=lf
# nginx /docker-entrypoint.d/*.envsh scripts are sourced as POSIX shell; CRLF
# would corrupt the heredoc body written into dynamic-env.json.
*.envsh text eol=lf

# Husky hook scripts have no extension but are POSIX shell scripts
angular/.husky/pre-commit text eol=lf
angular/.husky/commit-msg text eol=lf
angular/.husky/pre-push text eol=lf

# Dockerfiles + docker-compose: must stay LF on every host. Even though the
# Docker daemon parses Dockerfile syntax fine with CRLF, any heredoc body
# (`COPY <<EOF ...`) is written into the resulting image verbatim including
# CR characters -- which then corrupts shebangs on shell scripts emitted via
# heredoc. We removed angular/Dockerfile.dev's heredoc on 2026-05-08 in
# favor of a real `dev-entrypoint.sh` file (covered by the *.sh rule above),
# but pinning Dockerfiles + compose to LF is the belt-and-suspenders that
# prevents the same class of bug if anyone ever reintroduces a heredoc.
Dockerfile text eol=lf
Dockerfile.* text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf

# --- Generated code: keep out of diffs/line-counts; collapse on GitHub ---
# `-diff` makes git render these as "binary" so they don't count toward +/- line
# totals (locally or on GitHub). `linguist-generated=true` collapses them in PR
# diffs and removes them from the language-stats bar. The files stay fully tracked
# and committed and remain openable in an editor -- ONLY the diff rendering changes;
# nothing functional is affected.
**/Migrations/**          linguist-generated=true -diff
**/TenantMigrations/**    linguist-generated=true -diff
angular/src/app/proxy/**  linguist-generated=true -diff
