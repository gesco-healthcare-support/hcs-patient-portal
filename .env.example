# Development secrets — copy this file to .env.local and fill in real values
# .env.local is gitignored and will not be committed

# ABP Commercial NuGet feed API key (used in NuGet.Config)
ABP_NUGET_API_KEY=your-abp-nuget-api-key-guid

# Certificate passphrase for OpenIddict signing cert
CERT_PASSPHRASE=generate-a-guid

# Docker compose cert password
CERT_PASSWORD=generate-a-guid

# String encryption passphrase (AuthServer + HttpApi.Host appsettings)
STRING_ENCRYPTION_PASSPHRASE=generate-a-16-char-key

# Default test/seed password for admin and test users
TEST_PASSWORD=your-test-password

# Helm/Docker SQL Server SA password
SA_PASSWORD=your-sa-password

# Helm dbmigrator auth server client secret
AUTH_SERVER_CLIENT_SECRET=your-client-secret
