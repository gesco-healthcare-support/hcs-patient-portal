# Docker Compose environment variables
# Copy to .env and fill in real values: cp .env.example .env
# Also copy your ABP secrets: cp docker/appsettings.secrets.json.example docker/appsettings.secrets.json
#
# Prerequisites:
#   - Docker Desktop running
#   - ABP CLI logged in: dotnet tool install -g Volo.Abp.Studio.Cli && abp login <your-email>
#     This creates ~/.abp/cli/access-token.bin which Docker mounts into containers.

# SQL Server SA password (Docker-only, any strong password)
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# ABP Commercial NuGet feed API key (GUID from your ABP account)
ABP_NUGET_API_KEY=your-abp-nuget-api-key-guid

# String encryption passphrase (16+ characters)
STRING_ENCRYPTION_PASSPHRASE=your-16-char-encryption-key

# ABP license code (long base64 string from appsettings.secrets.json)
ABP_LICENSE_CODE=paste-your-abp-license-code-here

# ----------------------------------------------------------------------------
# Per-worktree compose overrides
# ----------------------------------------------------------------------------
# docker-compose.yml reads these to isolate host ports + URLs between worktrees
# running concurrently. Main keeps the defaults; dev / staging / feature
# worktrees override in their own .env to avoid port collisions. scripts/
# worktrees/add-worktree.sh auto-writes this block for feature worktrees.
# See docs/runbooks/DOCKER-DEV.md -> "Running multiple worktrees concurrently".

#AUTH_PORT=44378         # default 44368 (main)
#API_PORT=44337          # default 44327 (main)
#NG_PORT=4210            # default 4200  (main)
#SQL_HOST_PORT=1444      # default 1434  (main)
#REDIS_HOST_PORT=6389    # default 6379  (main)

# Angular build target. Main uses 'docker' (environment.docker.ts bakes main's
# URLs). Dev / staging / feature worktrees set 'local' so the image is built
# with environment.local.ts (whose URLs scripts/worktrees/render-config.sh
# generates per worktree). The file is gitignored.
#NG_CONFIG=local

# Database name inside the per-worktree SQL container. Each worktree's compose
# project gets its own SQL server, so the DB name can be the same across
# worktrees (default 'CaseEvaluation'). Set this only if you point two projects
# at a shared SQL instance.
#DB_NAME=CaseEvaluation_development
