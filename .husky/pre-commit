#!/usr/bin/env sh

echo "Running pre-commit checks..."

# 1. SECRET DETECTION (most critical for public repo)
if command -v gitleaks > /dev/null 2>&1; then
  echo "  Scanning for secrets..."
  gitleaks protect --staged --verbose
  if [ $? -ne 0 ]; then
    echo "Gitleaks found secrets in staged files. Fix before committing."
    exit 1
  fi
else
  echo "  Warning: gitleaks not installed. Skipping secret scan."
  echo "  Install: https://github.com/gitleaks/gitleaks#installing"
fi

# 2. ANGULAR LINT + FORMAT (only staged files)
if [ -d "angular/node_modules" ]; then
  echo "  Linting Angular files..."
  cd angular && npx lint-staged
  LINT_EXIT=$?
  cd ..
  if [ $LINT_EXIT -ne 0 ]; then
    echo "Angular lint/format failed. Fix before committing."
    exit 1
  fi
fi

# 3. DOTNET FORMAT CHECK (only staged .cs files)
CS_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.cs')
if [ -n "$CS_FILES" ]; then
  echo "  Checking C# formatting..."
  dotnet format HealthcareSupport.CaseEvaluation.slnx --verify-no-changes --include $CS_FILES 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "C# formatting issues found. Run 'dotnet format' to fix."
    exit 1
  fi
fi

echo "Pre-commit checks passed."
